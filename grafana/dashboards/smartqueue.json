{
  "title": "Smart Task Queue",
  "uid": "smartqueue-v2",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Created / min",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(jobs_created_total{application=\"smart-task-queue\"}[1m]) * 60",
          "legendFormat": "created/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 2,
      "title": "Jobs Failed / min",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(jobs_failed_total{application=\"smart-task-queue\"}[1m]) * 60",
          "legendFormat": "failed/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 3,
      "title": "Job Processing Latency P95 (seconds)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(job_processing_duration_seconds_bucket{application=\"smart-task-queue\"}[5m])) by (le))",
          "legendFormat": "P95 latency"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(job_processing_duration_seconds_bucket{application=\"smart-task-queue\"}[5m])) by (le))",
          "legendFormat": "P50 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Failure Rate %",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * rate(jobs_failed_total{application=\"smart-task-queue\"}[5m]) / (rate(jobs_created_total{application=\"smart-task-queue\"}[5m]) + 0.0001)",
          "legendFormat": "failure rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Active Jobs (PROCESSING)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "active_jobs_count{application=\"smart-task-queue\"}",
          "legendFormat": "active jobs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "graphMode": "none",
        "colorMode": "background"
      }
    },
    {
      "id": 6,
      "title": "DLQ Size (failed jobs)",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 16,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "dlq_size{application=\"smart-task-queue\"}",
          "legendFormat": "DLQ size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "graphMode": "none",
        "colorMode": "background"
      }
    },
    {
      "id": 7,
      "title": "Jobs Completed Total",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 16,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jobs_completed_total{application=\"smart-task-queue\"}",
          "legendFormat": "completed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "graphMode": "none",
        "colorMode": "background"
      }
    },
    {
      "id": 8,
      "title": "Classification Cache Hit Rate %",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * rate(classification_cache_hits_total{application=\"smart-task-queue\"}[5m]) / (rate(classification_cache_hits_total{application=\"smart-task-queue\"}[5m]) + rate(classification_cache_misses_total{application=\"smart-task-queue\"}[5m]) + 0.0001)",
          "legendFormat": "cache hit rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Retry Rate / min",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(jobs_retried_total{application=\"smart-task-queue\"}[1m]) * 60",
          "legendFormat": "retries/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      }
    }
  ]
}